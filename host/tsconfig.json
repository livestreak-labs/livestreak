{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "#api/*": ["./src/interfaces/api/*"],
      "#config/*": ["./src/config/*"],
      "#services/*": ["./src/services/*"],
      "#infrastructure/*": ["./src/infrastructure/*"],
      "#test/*": ["./test/*"]
    }
  },
  "include": ["src", "test"]
}
