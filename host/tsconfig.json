{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "#server/*": ["./src/server/*"],
      "#descriptor/*": ["./src/descriptor/*"],
      "#media/*": ["./src/media/*"],
      "#discovery/*": ["./src/discovery/*"],
      "#memory/*": ["./src/memory/*"],
      "#aa/*": ["./src/aa/*"],
      "#test/*": ["./test/*"]
    }
  },
  "include": ["src", "test"]
}
