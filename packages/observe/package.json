{
  "name": "@livestreak/observe",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "imports": {
    "#pipeline/*": "./dist/pipeline/*",
    "#adapters/*": "./dist/adapters/*",
    "#run/*": "./dist/run/*",
    "#bridge/*": "./dist/bridge/*",
    "#scope/*": "./dist/scope/*",
    "#market/*": "./dist/market/*",
    "#flows/*": "./dist/flows/*",
    "#builtins.js": "./dist/builtins.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "dev": "tsc -w -p tsconfig.build.json"
  },
  "dependencies": {
    "@livestreak/contracts": "file:../contracts",
    "@livestreak/core": "file:../core",
    "@livestreak/schema": "file:../schema",
    "@livestreak/wallet": "file:../wallet",
    "effect": "3.21.3",
    "uuid": "^11.1.1",
    "viem": "^2.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@roamhq/wrtc": "^0.8.0"
  }
}
