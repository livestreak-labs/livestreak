{
  "name": "@livestreak/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./evm/generated/contracts.ts"
  },
  "files": [
    "evm/generated/",
    "evm/foundry.toml",
    "evm/src/"
  ],
  "scripts": {
    "clean": "rm -rf evm/out evm/cache evm/generated/contracts.ts",
    "build": "cd evm && forge build && FOUNDRY_PROFILE=aa forge build && wagmi generate",
    "check": "tsc -p evm/tsconfig.json --noEmit",
    "lint": "cd evm && forge fmt --check src test",
    "test": "cd evm && forge test"
  },
  "dependencies": {
    "viem": "^2.23.0"
  },
  "devDependencies": {
    "@wagmi/cli": "^2.10.0",
    "tsx": "^4.19.0",
    "typescript": "6.0.3"
  }
}
