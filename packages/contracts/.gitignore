# Foundry compiler artifacts
evm/cache/
evm/out/

# Legacy paths (pre-evm/ relocate)
cache/
out/

# Ignores development broadcast logs
!/evm/broadcast
/evm/broadcast/*/31337/
/evm/broadcast/**/dry-run/

node_modules/

# TS facade build output (regenerate via `npm run build`)
dist/

# Local deploy manifests (keep .gitkeep only)
evm/deploy/output/*.json
!evm/deploy/output/.gitkeep

# Legacy deploy output path
deploy/output/*.json
!deploy/output/.gitkeep

# Dotenv file
.env
