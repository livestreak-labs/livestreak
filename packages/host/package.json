{
  "name": "@livestreak/host",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "imports": {
    "#index.js": "./dist/index.js",
    "#test/*": "./test/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@livestreak/schema": "file:../schema",
    "effect": "3.21.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
