{
  "name": "@livestreak/bookmaker",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "e2e:chain": "npm run build -w @livestreak/wallet && tsx test/e2e/create-vault.e2e.ts",
    "dev": "tsc -w -p tsconfig.json"
  },
  "dependencies": {
    "@livestreak/contracts": "file:../contracts",
    "@livestreak/core": "file:../core",
    "@livestreak/host": "file:../host",
    "@livestreak/schema": "file:../schema",
    "@livestreak/wallet": "file:../wallet",
    "viem": "^2.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.19.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
