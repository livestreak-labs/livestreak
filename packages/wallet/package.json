{
  "name": "@livestreak/wallet",
  "version": "1.0.0-beta.5",
  "description": "Multichain BIP-32 wallet manager (EVM ERC-4337 Safe + Sui), vendored WDK glue with TS facade",
  "keywords": [
    "wdk",
    "wallet",
    "bip-32",
    "ethereum",
    "erc-4337",
    "sui"
  ],
  "author": "LiveStreak",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#chains/*": "./dist/chains/*",
    "#vendor/*": "./dist/vendor/*",
    "#types.js": "./dist/types.js",
    "#create-wallet-manager.js": "./dist/create-wallet-manager.js",
    "#index.js": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/vendor",
    "bare.js",
    "patches",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-vendored.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "pretest": "npm run build",
    "test": "node --test \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "@mysten/sui": "^1.21.1",
    "@safe-global/protocol-kit": "^6.1.2",
    "@safe-global/relay-kit": "^4.1.1",
    "@tetherto/wdk-failover-provider": "1.0.0-beta.2",
    "@tetherto/wdk-wallet": "1.0.0-beta.7",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.8",
    "bare-node-runtime": "^1.1.4",
    "bip39": "3.1.0",
    "ethers": "6.14.4",
    "micro-key-producer": "0.7.6",
    "sodium-universal": "5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bare": "./bare.js",
      "default": "./dist/index.js"
    },
    "./keystore": {
      "types": "./dist/keystore.d.ts",
      "default": "./dist/keystore.js"
    },
    "./package": {
      "default": "./package.json"
    }
  }
}
